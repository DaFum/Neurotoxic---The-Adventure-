    "dotenv": "^17.2.3",
    "lucide-react": "^1.7.0",
    "motion": "^12.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "overrides": {
      "@dimforge/rapier3d-compat": "^0.19.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
